PORT=4000

# Параметры подключения к PostgreSQL
# Скопируйте этот файл в .env и укажите свои значения
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=carwash_db

# Альтернатива: можно задать одну строку DATABASE_URL вместо DB_* переменных
# DATABASE_URL=postgres://user:password@localhost:5432/carwash_db

JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d
