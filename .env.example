# =============================================================================
# CarWash — Docker Compose параметры
# =============================================================================
# Скопируйте этот файл в .env и заполните свои значения.
# Этот файл используется docker-compose.yml

# --- PostgreSQL ---
POSTGRES_DB=carwash_db
POSTGRES_USER=carwash_user
POSTGRES_PASSWORD=carwash_pass
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=4000
JWT_SECRET=super_secret_key_carwash_2024
JWT_EXPIRES_IN=7d

# --- Frontend ---
FRONTEND_PORT=5173
